# --- Required ---
DATABASE_URL="postgresql://user:pass@host:5432/shopdesk"
NEXTAUTH_URL="https://your-app.up.railway.app"   # also used for customer signing + payment links
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Encrypts per-shop secrets (SMTP password, Stripe keys, Twilio token) at rest.
# Falls back to NEXTAUTH_SECRET if unset — set it anyway so you can rotate auth without re-keying secrets.
APP_ENCRYPTION_KEY="generate-with: openssl rand -base64 32"

# --- Optional platform-level SMTP fallback (shops can set their own in Settings → Integrations) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# --- First-run seed (npm run db:seed) ---
SEED_SHOP_NAME="My Auto Repair"
SEED_OWNER_NAME="Owner"
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_PASSWORD="changeme123"
